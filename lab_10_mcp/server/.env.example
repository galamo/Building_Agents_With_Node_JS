# Required — OpenRouter API key
OPENROUTER_API_KEY=

# Optional — model (default: openai/gpt-4o-mini)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Quiz MCP server URL (default: http://localhost:3100/mcp)
# MCP_QUIZ_URL=http://localhost:3100/mcp

# Agent server port (default 3010)
# PORT=3010

# Verbose LangChain agent logging
# VERBOSE=true
