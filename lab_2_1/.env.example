# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# openai/gpt-5.4 or openai/gpt-5.5 (default)
OPENROUTER_MODEL=openai/gpt-5.5

# Image model for story illustrations (used with --image)
OPENROUTER_IMAGE_MODEL=openai/gpt-image-1-mini

# Optional: override the built-in system prompt
# SYSTEM_PROMPT=You write short happy stories for kids...
