# One of these is required for LLM and embeddings
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional: override if not using defaults (docker-compose)
# PG_HOST=127.0.0.1
# PG_PORT=5433
# PG_USER=sso_user
# PG_PASSWORD=sso_pass
# PG_DATABASE=sso_db

# Optional: server port (default 3002)
# PORT=3002

# Mermaid MCP server (for use_mermaid_diagram router tool). Copy from Cursor mcp.json if needed.
# MCP_MERMAID_URL=https://mcp.mermaid.ai/mcp
# MCP_MERMAID_AUTH=<your-mermaid-mcp-authorization-header-value>
